<Project Sdk="MSBuild.Sdk.SqlProj/4.1.0">
  <!-- ProjectModel is the active source of truth. -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <SqlServerVersion>Sql150</SqlServerVersion>
    <TargetName>ASBDEM</TargetName>
    <RunSqlCodeAnalysis>False</RunSqlCodeAnalysis>
    <TreatTSqlWarningsAsErrors>False</TreatTSqlWarningsAsErrors>
    <IncludeCompositeObjects>True</IncludeCompositeObjects>
    <GenerateCreateScript>True</GenerateCreateScript>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.SqlServer.Dacpacs.Master" Version="170.0.3" DacpacName="master" DatabaseVariableLiteralValue="master" />
  </ItemGroup>

  <ItemGroup>
    <Content Remove="Tests\**\*.sql" />
  </ItemGroup>

  <ItemGroup>
    <PostDeploy Include="Post-Deployment\Script.PostDeployment.sql" />
  </ItemGroup>
</Project>